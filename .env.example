# NicheFit — copy to .env and fill in. Leave a key blank to run that layer in MOCK mode.

# Apify API token (the follower data layer). console.apify.com -> Settings -> API tokens
APIFY_API_TOKEN=

# Anthropic API key (the scoring brain, Claude Haiku). console.anthropic.com
ANTHROPIC_API_KEY=

# ---- optional overrides (sane defaults in nichefit/config.py) ----
# NICHEFIT_FORCE_MOCK=1            # force both layers into mock mode (used by tests)
# HOST=127.0.0.1
# PORT=8000
# HAIKU_MODEL=claude-haiku-4-5
# DEFAULT_SAMPLE_SIZE=2000
# HARD_CAP_SAMPLE_SIZE=50000
# DEFAULT_CONCURRENCY=8
# APIFY_COST_PER_1000_FOLLOWERS=0.13
# HAIKU_INPUT_PRICE_PER_MTOK=1.0
# HAIKU_OUTPUT_PRICE_PER_MTOK=5.0
# APIFY_ACTOR_ID=kaitoeasyapi/premium-x-follower-scraper-following-data
